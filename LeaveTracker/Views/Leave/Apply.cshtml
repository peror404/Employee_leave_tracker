@model LeaveTracker.Models.LeaveRequest
@{
    ViewBag.Title = "Apply for Leave";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
<div class="col-md-7">
<div class="card p-4">
    <h4 class="mb-4 fw-bold text-primary">📋 Apply for Leave</h4>

    @using (Html.BeginForm("Apply", "Leave", FormMethod.Post))
    {
        @Html.AntiForgeryToken()

        <div class="mb-3">
            @Html.LabelFor(m => m.EmployeeId, new { @class = "form-label fw-semibold" })
            @Html.DropDownListFor(m => m.EmployeeId,
                ViewBag.Employees as SelectList,
                "-- Select Employee --",
                new { @class = "form-select" })
            @Html.ValidationMessageFor(m => m.EmployeeId, "", new { @class = "text-danger small" })
        </div>

        <div class="mb-3">
            @Html.LabelFor(m => m.LeaveType, new { @class = "form-label fw-semibold" })
            @Html.DropDownListFor(m => m.LeaveType,
                new SelectList(new[] { "Sick", "Casual", "Annual" }),
                "-- Select Type --",
                new { @class = "form-select" })
            @Html.ValidationMessageFor(m => m.LeaveType, "", new { @class = "text-danger small" })
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                @Html.LabelFor(m => m.StartDate, new { @class = "form-label fw-semibold" })
                @Html.TextBoxFor(m => m.StartDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                @Html.ValidationMessageFor(m => m.StartDate, "", new { @class = "text-danger small" })
            </div>
            <div class="col-md-6 mb-3">
                @Html.LabelFor(m => m.EndDate, new { @class = "form-label fw-semibold" })
                @Html.TextBoxFor(m => m.EndDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                @Html.ValidationMessageFor(m => m.EndDate, "", new { @class = "text-danger small" })
            </div>
        </div>

        <div class="mb-4">
            @Html.LabelFor(m => m.Reason, new { @class = "form-label fw-semibold" })
            @Html.TextAreaFor(m => m.Reason, new { @class = "form-control", rows = 3, placeholder = "Brief reason for leave..." })
            @Html.ValidationMessageFor(m => m.Reason, "", new { @class = "text-danger small" })
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4">Submit Request</button>
            <a href="/Leave" class="btn btn-outline-secondary">Cancel</a>
        </div>
    }
</div>
</div>
</div>
